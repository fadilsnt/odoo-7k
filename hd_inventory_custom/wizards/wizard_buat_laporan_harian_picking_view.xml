<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- FORM VIEW -->
    <record id="view_wizard_buat_laporan_harian_picking_form" model="ir.ui.view">
        <field name="name">wizard.buat.laporan.harian.picking.form</field>
        <field name="model">wizard.buat.laporan.harian.picking</field>
        <field name="arch" type="xml">
            <form string="Laporan Harian Picking">
                <div class="oe_title" style="width: 100%; max-width: 100%; padding-right: 0 !important; border-bottom: 1px solid #ddd; padding-bottom: 10px; margin-bottom: 15px;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span class="o_form_label text-muted" style="font-size: 13px;">Operations</span>
                            <h1 style="margin: 0; font-weight: 600;">
                                <field name="picking_id" readonly="1"/>
                            </h1>
                        </div>

                        <!-- Kanan: Location -->
                        <div class="text-end">
                            <span class="o_form_label text-muted" style="font-size: 13px;">To</span>
                            <div style="font-size: 16px; font-weight: 500;">
                                <field name="location_dest_id" readonly="1" class="fw-bold"/>
                            </div>
                        </div>

                    </div>

                </div>                   
                <group>
                    <group>
                        <field name="oven_number"/>
                        <field name="line_packing"/>
                        <field name="camp_tgl_briket" string="Campuran"/>
                        <field name="briket_tgu"/>
                        <field name="shift_briket"/>
                    </group>
                    <group>
                        <field name="production_date" string="Tanggal Briket"/>
                        <field name="bkr"/>
                        <field name="pembakar_penutup"/>
                        <field name="asumsi_berat_ikat"/>
                        <field name="lubang_setom" />
                        <field name="bongkaran" />
                    </group>
                </group>

                <notebook>
                    <page name="line_ids" string="Product Lines">
                        <field name="product_line_ids">
                            <list editable="bottom">
                                <field name="product_id"/>
                                <field name="tonase_asli" column_invisible="1"/>
                                <field name="qty"/>
                                <field name="product_uom_id" />
                            </list>
                        </field>
                    </page>
                </notebook>

                <footer>
                    <button name="action_apply"
                            string="Apply"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>

            </form>
        </field>
    </record>


    <!-- ACTION -->
    <record id="action_wizard_buat_laporan_harian_picking" model="ir.actions.act_window">
        <field name="name">Laporan Harian Picking</field>
        <field name="res_model">wizard.buat.laporan.harian.picking</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>    
</odoo>