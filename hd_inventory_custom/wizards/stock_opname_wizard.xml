<?xml version="1.0"?>
<odoo>
    
    <record id="view_stock_opname_wizard" model="ir.ui.view">
        <field name="name">stock.opname.wizard</field>
        <field name="model">stock.opname.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="warehouse_id" options="{'no_open': True, 'no_create': True}"/>
                        <field name="category_ids" widget="many2many_tags"/>
                        <field name="as_of_date"/>
                    </group>
                </group>
                <footer>
                    <button name="button_print" string="Cetak Excel" type="object" class="oe_highlight"/>
                    <button string="Batal" class="oe_link" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_stock_opname_wizard">
        <field name="name">Laporan Opname</field>
        <field name="res_model">stock.opname.wizard</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_stock_opname_wizard"/>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_stock_opname_wizard" name="Laporan Opname" action="action_stock_opname_wizard" parent="export_stock_report.menu_print_stock_report" sequence="20"/>
    
</odoo>