        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">94</field>        
    </record>        

    <record id="action_report_stock_persediaan" model="ir.actions.report">
        <field name="name">Report Stok Persediaan</field>
        <field name="model">stock.quant</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">export_stock_report.stok_persediaan_report</field>
        <field name="report_file">export_stock_report.stok_persediaan_report</field>
        <field name="paperformat_id" ref="export_stock_report.paperformat_landscape_laporan_persediaan"/>
        <field name="binding_model_id" ref="stock.model_stock_quant"/>
        <field name="binding_type">report</field>
    </record>        
</odoo>
